diff --git a/tmenu_path_desktop b/tmenu_path_desktop
new file mode 100644
index 0000000..e2b20d2
--- /dev/null
+++ b/tmenu_path_desktop
@@ -0,0 +1,19 @@
+#!/bin/sh
+
+cachedir="${XDG_CACHE_HOME:-"$HOME/.cache"}"
+cache="$cachedir/tmenu_run_desktop"
+
+[ ! -e "$cachedir" ] && mkdir -p "$cachedir"
+
+dirs=""
+IFS=:
+for dir in "${XDG_DATA_DIRS:-"/usr/local/share:/usr/share"}"; do
+       dirs="${dirs}:${dir}/applications"
+done;
+
+if stest -dqr -n "$cache" $PATH; then
+       stest -fl $dirs | grep -v mimeinfo.cache | sed s/.[^./]*$// | sort -u | tee "$cache"
+else
+       cat "$cache"
+fi
+
